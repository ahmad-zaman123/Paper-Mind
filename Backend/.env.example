# Copy to .env and fill in. For local dev the defaults below are enough.

SECRET_KEY=django-insecure-change-me
DEBUG=True

# Leave unset to use local SQLite. For Neon Postgres + pgvector, set the pooled URL:
# DATABASE_URL=postgresql://user:pass@host-pooler.region.aws.neon.tech/db?sslmode=require

# Google Gemini (free tier from https://aistudio.google.com — NOT Vertex AI)
GEMINI_API_KEY=

# Frontend origins allowed to call the API
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
